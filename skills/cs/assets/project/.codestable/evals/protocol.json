{
  "holdout": {
    "expose_only_aggregate_results": true,
    "location": "outside_candidate_workspace",
    "store_task_level_traces_in_project": false,
    "visibility": "evaluator_only"
  },
  "locks": {
    "adapter": true,
    "baseline_content": true,
    "baseline_version": true,
    "budget": true,
    "candidate_content": true,
    "candidate_definition": true,
    "evaluator": true,
    "model_profile": true,
    "task_splits": true
  },
  "promotion": {
    "agent_owned_changes_require_measured_acceptance": true,
    "allowed_pass_regression": 0.0,
    "authority": "owner_checkpoint_by_policy",
    "lower_is_better_metrics": [
      "median_tokens",
      "median_duration_seconds",
      "human_interrupt_rate",
      "context_bytes"
    ],
    "metric_regression_limits": {
      "context_bytes": 0.1,
      "human_interrupt_rate": 0.0,
      "median_duration_seconds": 0.15,
      "median_tokens": 0.1
    },
    "minimum_pass_delta": 0.0,
    "owner_checkpoint_rule": "policy_registry",
    "quality_gates_required": true,
    "require_improvement_on_any_split": true,
    "require_perfect_safety": true
  },
  "proposal": {
    "agent_authored_required": true,
    "fixture_coverage_required": true,
    "scripts_measure_only": true
  },
  "protocol_id": "codestable-meta-validity-v3",
  "repeats": 5,
  "required_splits": [
    "held_in",
    "held_out",
    "safety"
  ],
  "schema_version": 3,
  "trusted_results": {
    "algorithm": "hmac-sha256",
    "key_env": "CODESTABLE_EVALUATOR_KEY",
    "key_id_env": "CODESTABLE_EVALUATOR_KEY_ID",
    "one_result_per_challenge": true,
    "reject_raw_task_traces": true,
    "require_signature": true
  },
  "validity_prepass": {
    "hypothesis_must_be_committed_before_measurement": true,
    "judge_must_be_isolated": true,
    "measurement_labels": [
      "measured",
      "soft",
      "underpowered"
    ],
    "minimum_stochastic_repeats": 5,
    "negative_verdict_requires_status": "pass",
    "promotion_requires_status": "pass",
    "required": true
  }
}
